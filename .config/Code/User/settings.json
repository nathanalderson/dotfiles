{
    "window.commandCenter": false,
    "window.titleBarStyle": "custom",
    "window.menuBarVisibility": "toggle",
    "workbench.colorTheme": "Monokai Pro (Filter Machine)",
    "workbench.editor.showTabs": "single",
    "workbench.layoutControl.enabled": false,
    "breadcrumbs.symbolPath": "off",
    "editor.fontFamily": "'Fantasque Sans Mono', monospace",
    "editor.fontLigatures": "",
    "editor.formatOnSave": true,
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorBlinking": "phase",
    "editor.cursorSurroundingLines": 3,
    "editor.minimap.enabled": false,
    "editor.find.loop": false,
    "editor.guides.indentation": false,
    "editor.inlineSuggest.enabled": true,
    "explorer.autoReveal": false,
    "explorer.decorations.badges": false,
    "extensions.ignoreRecommendations": true,
    "vscode-neovim.compositeKeys": {
        "jk": {
            "command": "vscode-neovim.escape",
        }
    },
    "files.autoSave": "onWindowChange",
    "elixirLS.envVariables": {
        "ELIXIR_WARNINGS_OK": "1"
    },
    "elixirLS.suggestSpecs": false,
    "elixirLS.dialyzerEnabled": false,
    "exunit.saveAllBeforeRun": true,
    "[elixir]": {
        "editor.formatOnType": true,
        "editor.formatOnSave": true,
        "editor.formatOnPaste": true,
        "editor.tabSize": 2,
    },
    "[html-eex]": {
        "editor.formatOnType": true,
        "editor.formatOnSave": true,
        "editor.formatOnPaste": true,
        "editor.tabSize": 2
    },
    "[html]": {
        "editor.tabSize": 2,
        "editor.defaultFormatter": "monosans.djlint",
    },
    "html.autoClosingTags": false,
    "html.autoCreateQuotes": false,
    "djlint.showInstallError": false,
    "[javascript]": {
        "editor.tabSize": 2,
        "editor.formatOnSave": true
    },
    "[yaml]": {
        "editor.tabSize": 2,
        "editor.formatOnSave": true,
        "editor.detectIndentation": false
    },
    "[python]": {
        "editor.formatOnType": true,
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        },
        "defaultInterpreterPath": "/bin/python",
        "diffEditor.ignoreTrimWhitespace": false
    },
    "isort.args": [
        "--profile",
        "black"
    ],
    // This allows ctrl-p to function as "previous" in the terminal
    "terminal.integrated.commandsToSkipShell": [
        "-workbench.action.quickOpen"
    ],
    "terminal.integrated.stickyScroll.enabled": false,
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.localEchoLatencyThreshold": 100,
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "terminal.integrated.suggest.enabled": false,
    "terminal.integrated.smoothScrolling": true,
    "terminal.integrated.mouseWheelScrollSensitivity": 0.4,
    "debug.openDebug": "openOnDebugBreak",
    "[dart]": {
        "editor.formatOnSave": true,
        "editor.formatOnType": true,
        "editor.selectionHighlight": false,
        "editor.suggest.snippetsPreventQuickSuggestions": false,
        "editor.suggestSelection": "first",
